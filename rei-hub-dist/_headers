/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; connect-src 'self' https://api.stripe.com https://api.anthropic.com https://integrate.api.nvidia.com https://secure.shippingapis.com https://fax.twilio.com https://api.twilio.com; frame-src https://js.stripe.com; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline';

/assets/*
  Cache-Control: public, max-age=31536000, immutable
