# REI Fundamentals Hub — Frontend Environment Variables

# REI Hub backend (auth & billing)
VITE_REI_SERVER_URL=http://localhost:8001

# Published lead capture sites URL (dedicated subdomain)
VITE_SITES_URL=https://sites.reifundamentalshub.com

# Stripe publishable key (for embedded checkout)
VITE_STRIPE_PUBLISHABLE_KEY=

# Helm Hub integration (AI proxy)
# Helm Hub URL (for plugin data bridge)
VITE_HELM_HUB_URL=http://localhost:8000

# TPHS Payment Portal (Stripe Connect publishable key)
VITE_STRIPE_CONNECT_PUBLISHABLE_KEY=
