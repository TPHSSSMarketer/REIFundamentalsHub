REI_ENVIRONMENT=development
REI_DATABASE_URL=sqlite+aiosqlite:///./rei_hub.db
REI_JWT_SECRET=change-me-in-production
REI_JWT_ALGORITHM=HS256
REI_JWT_EXPIRATION_MINUTES=1440
REI_CORS_ORIGINS=http://localhost:3000

# ── HttpOnly Cookie Auth ──────────────────────────────────────────
# Access token lives 15 min (short-lived for security)
REI_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lives 7 days (long-lived, rotated on each refresh)
REI_REFRESH_TOKEN_EXPIRE_DAYS=7
# Cookie security — set to true in production (requires HTTPS)
REI_COOKIE_SECURE=false
# SameSite policy — "lax" allows OAuth redirects
REI_COOKIE_SAME_SITE=lax
# Cookie domain — leave empty for localhost, set to ".yourdomain.com" in prod
REI_COOKIE_DOMAIN=
# CSRF header name — frontend sends this with state-changing requests
REI_CSRF_HEADER_NAME=X-CSRF-Token
REI_STRIPE_SECRET_KEY=sk_test_your_key_here
REI_STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
REI_STRIPE_STARTER_MONTHLY_PRICE_ID=price_your_id_here
REI_STRIPE_STARTER_ANNUAL_PRICE_ID=price_your_id_here
REI_STRIPE_PRO_MONTHLY_PRICE_ID=price_your_id_here
REI_STRIPE_PRO_ANNUAL_PRICE_ID=price_your_id_here
REI_STRIPE_TEAM_MONTHLY_PRICE_ID=price_your_id_here
REI_STRIPE_TEAM_ANNUAL_PRICE_ID=price_your_id_here
REI_STRIPE_STARTER_ADDON_MONTHLY_PRICE_ID=price_your_id_here
REI_STRIPE_STARTER_ADDON_ANNUAL_PRICE_ID=price_your_id_here
REI_STRIPE_PRO_ADDON_MONTHLY_PRICE_ID=price_your_id_here
REI_STRIPE_PRO_ADDON_ANNUAL_PRICE_ID=price_your_id_here
REI_PAYPAL_CLIENT_ID=your_paypal_client_id_here
REI_PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
REI_PAYPAL_MODE=sandbox
REI_PAYPAL_STARTER_MONTHLY_PLAN_ID=your_plan_id_here
REI_PAYPAL_STARTER_ANNUAL_PLAN_ID=your_plan_id_here
REI_PAYPAL_PRO_MONTHLY_PLAN_ID=your_plan_id_here
REI_PAYPAL_PRO_ANNUAL_PLAN_ID=your_plan_id_here
REI_PAYPAL_TEAM_MONTHLY_PLAN_ID=your_plan_id_here
REI_PAYPAL_TEAM_ANNUAL_PLAN_ID=your_plan_id_here
REI_PAYPAL_STARTER_ADDON_MONTHLY_PLAN_ID=your_plan_id_here
REI_PAYPAL_STARTER_ADDON_ANNUAL_PLAN_ID=your_plan_id_here
REI_PAYPAL_PRO_ADDON_MONTHLY_PLAN_ID=your_plan_id_here
REI_PAYPAL_PRO_ADDON_ANNUAL_PLAN_ID=your_plan_id_here
REI_PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
REI_PLUGIN_SHARED_SECRET=change-me-in-production
REI_HUB_URL=http://localhost:5173
REI_SENDGRID_API_KEY=your_sendgrid_api_key_here
REI_EMAIL_FROM=noreply@reifundamentalshub.com
REI_EMAIL_FROM_NAME=REIFundamentals Hub

# ── Plaid (Proof of Funds Verification) ──────────────────────
# Sign up at https://dashboard.plaid.com
# Use sandbox for testing — no real bank needed
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Document Automation ───────────────────────────────────────
# Templates use {{FIELD_NAME}} placeholder syntax.
# Supported fields: COMPANY_NAME, HOMEOWNER_NAME,
#   BUYING_ENTITY, PROPERTY_ADDRESS, PURCHASE_PRICE,
#   CLOSING_DATE, EMD_AMOUNT, ADDITIONAL_CLAUSES
# Also referenced as REI_GOOGLE_DRIVE_CREDENTIALS in some documentation
REI_GOOGLE_DRIVE_ACCESS_TOKEN=
REI_DROPBOX_ACCESS_TOKEN=

# ── Email Provider ────────────────────────────────────────────
# "resend" to start (simpler, cheaper at low volume)
# "sendgrid" when scaling (flip this one var to migrate)
# Switching providers = change this + add new API key
REI_EMAIL_PROVIDER=resend

# ── Resend (recommended to start) ────────────────────────────
# Sign up free at https://resend.com
# Free: 3,000 emails/mo | Paid: $20/mo for 50k
REI_RESEND_API_KEY=

# ── SendGrid (for scale — each client gets own account) ──────
# Flip EMAIL_PROVIDER=sendgrid when ready to migrate
# Each of your platform clients gets their own
# SendGrid account connected here
# REI_SENDGRID_API_KEY=  (already set above)
REI_SENDGRID_WEBHOOK_SECRET=

# ── Email Plan Limits ─────────────────────────────────────────
# Starter: 5,000/mo | Pro: 25,000/mo | Team: 100,000/mo
# Overage: $1.50 per 1,000 emails

# ── Twilio (Phone System) ─────────────────────────────────────
# Sign up at twilio.com
# Get Account SID + Auth Token from Console Dashboard
REI_TWILIO_ACCOUNT_SID=
REI_TWILIO_AUTH_TOKEN=
REI_TWILIO_PHONE_NUMBER=
# Your Twilio phone number in E.164 format e.g. +12125551234
# Used as the "from" number for SMS, calls, and fax
# Create API Key: Twilio Console → Settings → API Keys
REI_TWILIO_API_KEY_SID=
REI_TWILIO_API_KEY_SECRET=
# Create TwiML App: Twilio Console → Voice → TwiML Apps
# Set Voice Request URL to:
# https://yourdomain.com/api/phone/webhook/voice
REI_TWILIO_TWIML_APP_SID=

# ── ElevenLabs (AI Voicemail — Pro plan+ only) ────────────────
# Sign up at elevenlabs.io
# Fallback: Twilio TTS used if ElevenLabs is unavailable
REI_ELEVENLABS_API_KEY=

# ── Phone Pricing Reference ───────────────────────────────────
# Outbound calls:    $0.03/min
# Inbound calls:     $0.03/min
# Outbound SMS:      $0.02/msg
# Inbound SMS:       Free
# Fax sent:          $0.04/page
# Fax received:      $0.02/page
# Additional numbers:$2.00/mo (1st included in plan)
# AI voicemail drop: $0.25/drop (Pro+ only)
# Standard drop:     $0.05/drop
#
# Credits NEVER expire and roll over month to month.
# Plan allotments (minutes/SMS) reset monthly.

# ── AI Provider System ────────────────────────────────────────
# NVIDIA Kimi K2 (default provider)
# Fallback chain: nvidia_kimi → nvidia_minimax → anthropic

# NVIDIA NIM API (Kimi 2.5, MiniMax 2.1, AI-Q)
# Get key at: build.nvidia.com → API Keys
REI_NVIDIA_API_KEY=

# Encryption key for storing user API keys
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
REI_AI_ENCRYPTION_KEY=

# Default AI provider for all accounts
# Options: anthropic, nvidia_kimi, nvidia_minimax, nvidia_aiq
REI_DEFAULT_AI_PROVIDER=nvidia_kimi
REI_DEFAULT_AI_MODEL=moonshotai/kimi-k2.5-instruct

# ── USPS Tracking API (OAuth V3) ─────────────────────────────
# Register at developers.usps.com and create an app in the COP
# Copy your Consumer Key and Consumer Secret
REI_USPS_CLIENT_ID=
REI_USPS_CLIENT_SECRET=

# ── Google Calendar ───────────────────────────────────────────
# console.cloud.google.com → Enable Calendar API
REI_GOOGLE_CLIENT_ID=
REI_GOOGLE_CLIENT_SECRET=
REI_GOOGLE_REDIRECT_URI=

# ── Microsoft Outlook Calendar ────────────────────────────────
# portal.azure.com → App registrations → New registration
# Add redirect URI for Outlook callback
# Permissions: Calendars.ReadWrite, offline_access
REI_OUTLOOK_CLIENT_ID=
REI_OUTLOOK_CLIENT_SECRET=
REI_OUTLOOK_REDIRECT_URI=

# ── Apple iCal (CalDAV) ───────────────────────────────────────
# No credentials needed here — users provide their own
# Apple ID + app-specific password during setup
# iCloud CalDAV URL: https://caldav.icloud.com

# ── Universal iCal Feed ───────────────────────────────────────
# No config needed — auto-generated per user
# Feed URL: {REI_HUB_URL}/api/calendar/feed/{token}.ics
# Works with: Apple Calendar, Google, Outlook,
#   Fantastical, Calendly, Yahoo, and any CalDAV app

# ── Onboarding ────────────────────────────────────────────────
# No additional env vars needed for onboarding.
# Twilio subaccount is auto-provisioned on completion.
# Storage OAuth configured separately.

# ── TPHS Payment Portal ───────────────────────────────────────
# Accessible at:
#   {REI_HUB_URL}/pay (embedded)
#   pay.tripointHomeSolutions.org (subdomain)
#
# Subdomain setup in nginx:
#   server {
#     server_name pay.tripointhomesolutions.org;
#     location / {
#       proxy_pass http://localhost:PORT;
#       proxy_set_header Host $host;
#     }
#   }
#
# Stripe Connect publishable key for
# payment form (TPHS account):
REI_STRIPE_CONNECT_SECRET_KEY=
REI_STRIPE_CONNECT_ACCOUNT_ID=
REI_STRIPE_CONNECT_PUBLISHABLE_KEY=
REI_TPHS_ADMIN_EMAIL=

# ── REI Hub Platform Stripe Account ──────────
# This is REI Hub's OWN Stripe account
# that receives servicing fees from tenants
REI_STRIPE_PLATFORM_ACCOUNT_ID=
