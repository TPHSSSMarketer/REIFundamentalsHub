# =============================================================================
# Helm AI Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# ── AI Backend ──────────────────────────────────────────────────────────────
# Options: "anthropic" (direct API), "openrouter" (gateway), "claude_cli" (Max sub)
AI_BACKEND=anthropic

# ── Anthropic (required when AI_BACKEND=anthropic) ──────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MODEL_OPUS=claude-opus-4-5

# ── OpenRouter (required when AI_BACKEND=openrouter) ────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5-20250929
OPENROUTER_MODEL_OPUS=anthropic/claude-opus-4-6

# ── Claude CLI (required when AI_BACKEND=claude_cli) ────────────────────────
# Uses your Claude Max subscription — no API credits needed.
# Install: npm install -g @anthropic-ai/claude-code
# Auth: run 'claude' once interactively to log in
CLAUDE_CLI_TIMEOUT=120

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Helm
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./helm.db

# ── REIFundamentals Hub Integration ──────────────────────────────────────────
REIFUNDAMENTALS_API_URL=https://api.reifundamentals.com/v1
REIFUNDAMENTALS_API_KEY=your-reifundamentals-api-key-here
REIFUNDAMENTALS_WEBHOOK_SECRET=your-webhook-secret-here
REI_HUB_URL=http://localhost:8001
REI_PLUGIN_SECRET=change-me-in-production

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
API_KEYS=
ADMIN_PASSWORD=change-me-in-production

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get your token.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook
TELEGRAM_ADMIN_USER_ID=

# ── WhatsApp (Meta Business Cloud API) ──────────────────────────────────────
# Set up via Meta Developer Portal → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=helm-whatsapp-verify
WHATSAPP_API_VERSION=v21.0

# ── Voice (OpenAI Whisper STT + TTS) ────────────────────────────────────────
# Uses OPENAI_API_KEY above if this is blank.
OPENAI_API_KEY_VOICE=
VOICE_STT_MODEL=whisper-1
VOICE_TTS_MODEL=tts-1
VOICE_TTS_VOICE=onyx

# ── GoHighLevel (optional CRM — works great without it) ────────────────────
# Register a Custom App in the GHL Developer Marketplace.
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=
GHL_ACCESS_TOKEN=
GHL_REFRESH_TOKEN=
GHL_LOCATION_ID=

# ── Supabase (optional persistent memory with semantic search) ──────────────
# Create a project at https://supabase.com, run the schema from CLAUDE.md.
# REQUIRED for production — get from Supabase project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Smart Check-ins ─────────────────────────────────────────────────────────
CHECKIN_ENABLED=false
CHECKIN_INTERVAL_MINUTES=30
CHECKIN_QUIET_HOURS_START=22
CHECKIN_QUIET_HOURS_END=7

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Google Drive Integration (optional) ──────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=your_client_id_here
GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret_here
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/cloud-storage/google-drive/callback
GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_DRIVE_REFRESH_TOKEN=

# ── Dropbox Integration (optional) ───────────────────────────────────────────
DROPBOX_APP_KEY=your_app_key_here
DROPBOX_APP_SECRET=your_app_secret_here
DROPBOX_REDIRECT_URI=http://localhost:8000/api/cloud-storage/dropbox/callback

# ── Helm Hub Standalone Billing (Solo / Pro plans) ───────────────────────────
HELM_STRIPE_SECRET_KEY=sk_test_your_key_here
HELM_STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
HELM_STRIPE_SOLO_MONTHLY_PRICE_ID=price_your_id_here
HELM_STRIPE_SOLO_ANNUAL_PRICE_ID=price_your_id_here
HELM_STRIPE_PRO_MONTHLY_PRICE_ID=price_your_id_here
HELM_STRIPE_PRO_ANNUAL_PRICE_ID=price_your_id_here
HELM_HUB_URL=http://localhost:8000

# ── Legacy Stripe (base/REI plugin billing) ──────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASE_PLAN_PRICE_ID=
STRIPE_REI_PLUGIN_PRICE_ID=

# ── PayPal ───────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_BASE_PLAN_ID=
PAYPAL_REI_PLUGIN_PLAN_ID=
PAYPAL_MODE=sandbox

# ── ElevenLabs (premium voice) ──────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=

# ── Slack ────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Microsoft Teams ─────────────────────────────────────────────────────
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ── Google Chat ──────────────────────────────────────────────────────────
GOOGLE_CHAT_SERVICE_ACCOUNT_KEY=

# ── Admin ────────────────────────────────────────────────────────────────
ADMIN_TENANT_ID=

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Workspace ────────────────────────────────────────────────────────────
WORKSPACE_ENABLED=true
WORKSPACE_MAX_SIZE_MB=100

# ── Billing URLs ─────────────────────────────────────────────────────────

BILLING_SUCCESS_URL=http://localhost:8000/billing?session_id={CHECKOUT_SESSION_ID}
BILLING_CANCEL_URL=http://localhost:8000/billing
