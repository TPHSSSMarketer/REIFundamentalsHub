# HelmEcosystem - Combined Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# ── Shared (both products use the same Supabase project) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Helm Hub (Python backend) ──────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
SECRET_KEY=generate_with_openssl_rand_hex_32
JWT_SECRET_KEY=generate_with_openssl_rand_hex_32
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
ELEVENLABS_API_KEY=your_elevenlabs_key
STRIPE_API_KEY=your_stripe_key
CHECKIN_INTERVAL_MINUTES=30
CHECKIN_QUIET_HOURS_START=22
CHECKIN_QUIET_HOURS_END=7
REI_PLUGIN_ENABLED=true

# ── REIFundamentals Hub (Vite React SPA) ───────────────────
# Note: VITE_ prefix = exposed in browser bundle
# Do NOT put secrets here - proxy sensitive calls through Helm Hub
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_HELM_HUB_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
VITE_GOOGLE_API_KEY=your_google_api_key