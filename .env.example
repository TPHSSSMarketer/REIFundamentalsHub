# REI Fundamentals Hub API Configuration
VITE_API_KEY=your_api_key_here
VITE_API_LOCATION_ID=your_default_location_id_here
VITE_API_BASE_URL=https://services.leadconnectorhq.com

# API Version (for API headers)
VITE_API_VERSION=2021-07-28

# Google Calendar Integration (for Smart Scheduler)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API, then create OAuth 2.0 Client ID and API Key
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your_google_api_key_here

# SaaS Mode — Multi-User Authentication (Supabase)
# Create a free project at https://supabase.com and run the migration in /supabase/migrations/
# Without these, the app runs in single-tenant mode (no login required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Chat Engine (Optional — enhances AI Chat with real LLM responses)
# Works with OpenAI, Anthropic (via proxy), or any OpenAI-compatible API
# Without these, the AI Chat uses a smart local response engine (no API key needed)
VITE_AI_API_KEY=your_openai_api_key_here
VITE_AI_API_URL=https://api.openai.com/v1
VITE_AI_MODEL=gpt-4o-mini
