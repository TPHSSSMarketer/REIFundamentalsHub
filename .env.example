# =============================================================================
# Helm AI Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# ── AI Provider ──────────────────────────────────────────────────────────────
# Anthropic (Claude) — primary AI engine
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Helm
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./helm.db

# ── REIFundamentals Hub Integration ──────────────────────────────────────────
REIFUNDAMENTALS_API_URL=https://api.reifundamentals.com/v1
REIFUNDAMENTALS_API_KEY=your-reifundamentals-api-key-here
REIFUNDAMENTALS_WEBHOOK_SECRET=your-webhook-secret-here

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
